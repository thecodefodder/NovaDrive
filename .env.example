FLASK_APP=novadrive.app:create_app
FLASK_ENV=development
SECRET_KEY=replace-this-with-a-long-random-secret
DATABASE_URL=sqlite:///instance/novadrive.db
# Leave blank to use Flask/request-derived URLs.
# Examples without scheme:
# - drive.example.com -> https://drive.example.com
# - 192.168.1.107:5000 -> http://192.168.1.107:5000
# - localhost:5000 -> http://localhost:5000
APP_EXTERNAL_URL=

MAX_UPLOAD_SIZE_BYTES=536870912
# Cloudflare upload compatibility:
# Turn this ON when NovaDrive is reached through Cloudflare Tunnel or a normal proxied
# Cloudflare hostname (orange cloud). NovaDrive will clamp uploads before Cloudflare
# returns 413 Payload Too Large at the edge.
# Turn this OFF when users connect directly to your server, over LAN/local IP, or through
# a DNS-only / grey-cloud Cloudflare record where Cloudflare is not proxying the upload.
# Effective upload limit becomes:
# min(MAX_UPLOAD_SIZE_BYTES, built-in safe Cloudflare plan cap)
CLOUDFLARE_TUNNEL_COMPAT=false
# Cloudflare plan to match when CLOUDFLARE_TUNNEL_COMPAT=true.
# Allowed values: free, pro, business, enterprise
# NovaDrive uses built-in conservative request-size caps so multipart uploads stay under
# Cloudflare's edge limit without needing another setting:
# - free: 99,000,000 bytes
# - pro: 99,000,000 bytes
# - business: 199,000,000 bytes
# - enterprise: 499,000,000 bytes
# Examples:
# - Using Cloudflare Tunnel on the free plan: CLOUDFLARE_TUNNEL_PLAN=free
# - Using a proxied domain on Business: CLOUDFLARE_TUNNEL_PLAN=business
# - Not using Cloudflare proxy/tunnel: leave CLOUDFLARE_TUNNEL_COMPAT=false and this value can stay as-is
CLOUDFLARE_TUNNEL_PLAN=free
SPOOL_MAX_MEMORY_BYTES=8388608
TEXT_PREVIEW_MAX_BYTES=1048576
DEFAULT_USER_STORAGE_QUOTA_BYTES=10737418240
DEFAULT_ADMIN_STORAGE_QUOTA_BYTES=0
SESSION_COOKIE_SECURE=false
PERMANENT_SESSION_LIFETIME_HOURS=24
# Turn this OFF to disable the public /auth/register page and make the site login-only.
# Admins can still create accounts from the admin dashboard or the CLI.
ALLOW_PUBLIC_REGISTRATION=true
# Label shown inside authenticator apps when users enable TOTP 2FA.
TWO_FACTOR_ISSUER_NAME=NovaDrive

STORAGE_BACKEND=discord
ALLOW_PUBLIC_SHARING=true
SOFT_DELETE_ENABLED=true
WEBDAV_ENABLED=true
WEBDAV_REALM=NovaDrive WebDAV
S3_ENDPOINT_URL=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SESSION_TOKEN=
S3_BUCKET_NAME=
S3_PREFIX=novadrive
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL_SECONDS=900

EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_MAX_AGE_SECONDS=86400
EMAIL_VERIFICATION_RESEND_INTERVAL_SECONDS=60
# Password recovery links sent from the login page or admin user details screen.
# Requires SMTP to be configured below.
PASSWORD_RESET_MAX_AGE_SECONDS=3600
PASSWORD_RESET_RESEND_INTERVAL_SECONDS=60

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=NovaDrive
SMTP_TIMEOUT_SECONDS=20

DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=123456789012345678
DISCORD_STORAGE_CHANNEL_IDS=123456789012345678,234567890123456789
DISCORD_ATTACHMENT_LIMIT_BYTES=8000000
DISCORD_CHUNK_MARGIN_BYTES=262144
DISCORD_CHUNK_SIZE_BYTES=7737856
DISCORD_BOT_BRIDGE_URL=http://127.0.0.1:5051
DISCORD_BOT_BRIDGE_SHARED_SECRET=replace-this-bridge-secret
DISCORD_BOT_BRIDGE_CONNECT_TIMEOUT_SECONDS=2
DISCORD_BOT_BRIDGE_TIMEOUT_SECONDS=60
DISCORD_UPLOAD_RETRY_COUNT=3
DISCORD_FETCH_RETRY_COUNT=0

SHARE_TOKEN_BYTES=24
LOG_LEVEL=INFO
